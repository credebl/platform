    "form-data": "^4.0.5"
  },
  "devDependencies": {
    "@nestjs/cli": "catalog:",
    "@nestjs/schematics": "catalog:",
    "@nestjs/testing": "catalog:",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.19.33",
    "@types/passport-jwt": "3.0.9",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.10.2",
    "eslint-config-standard-with-typescript": "^37.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^15.7.0",
    "eslint-plugin-prettier": "^4.2.5",
    "eslint-plugin-promise": "^6.6.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^13.3.0",
    "prettier": "^3.8.1",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "**/*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".spec.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/",
      "<rootDir>/test/"
    ],
    "moduleNameMapper": {
      "@credebl/common/(.*)": "<rootDir>/libs/common/src/$1",
      "@credebl/common": "<rootDir>/libs/common/src",
      "@credebl/keycloak-url/(.*)": "<rootDir>/libs/keycloak-url/src/$1",
      "@credebl/keycloak-url": "<rootDir>/libs/keycloak-url/src",
      "@credebl/client-registration/(.*)": "<rootDir>/libs/client-registration/src/$1",
      "@credebl/client-registration": "<rootDir>/libs/client-registration/src",
      "^@credebl/prisma-service(|/.*)$": "<rootDir>/libs/prisma-service/src/$1",
      "^@credebl/org-roles(|/.*)$": "<rootDir>/libs/user-management/src/$1",
      "@credebl/user-management": "<rootDir>/libs/user-management/src",
      "^@credebl/user-management(|/.*)$": "<rootDir>/libs/user-management/src/$1",
      "^@app/supabase(|/.*)$": "<rootDir>/libs/supabase/src/$1",
      "^@credebl/aws(|/.*)$": "<rootDir>/libs/aws/src/$1",
      "^@credebl/config(|/.*)$": "<rootDir>/libs/common/src/$1",
      "^@credebl/context(|/.*)$": "<rootDir>/libs/common/src/utils/context/$1",
      "^@credebl/logger(|/.*)$": "<rootDir>/libs/logger/src/$1",
      "^libs/(.*)$": "<rootDir>/libs/$1",
      "^apps/(.*)$": "<rootDir>/apps/$1",
      "@credebl/supabase": "<rootDir>/libs/supabase/src",
      "^@credebl/supabase(|/.*)$": "<rootDir>/libs/supabase/src/$1",
      "@credebl/keycloak-config": "<rootDir>/libs/keycloak-config/src",
      "^@credebl/keycloak-config(|/.*)$": "<rootDir>/libs/keycloak-config/src/$1",
      "^@credebl/enum(|/.*)$": "<rootDir>/libs/common/src/enum/$1",
      "^@credebl/user-request(|/.*)$": "<rootDir>/libs/user-management/src/$1",
      "^@credebl/user-activity(|/.*)$": "<rootDir>/libs/user-management/src/$1",
      "^@credebl/user-org-roles(|/.*)$": "<rootDir>/libs/user-management/src/$1"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/",
      "\\.js$"
    ],
    "setupFiles": [
      "<rootDir>/test/jest.setup.ts"
    ],
    "globals": {
      "ts-jest": {
        "diagnostics": {
          "ignoreCodes": [
            2345,
            2322,
            2769
          ]
        }
      }
    }
  },
  "packageManager": "pnpm@9.15.3+sha512.1f79bc245a66eb0b07c5d4d83131240774642caaa86ef7d0434ab47c0d16f66b04e21e0c086eb61e62c77efc4d7f7ec071afad3796af64892fae66509173893a",
  "engines": {
    "node": ">=18"
  },
  "private": true,
  "pnpm": {
    "overrides": {
      "@nestjs/core": "11.1.19",
      "@nestjs/common": "11.1.19",
      "@nestjs/microservices": "11.1.19"
    }
  }
}