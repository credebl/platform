    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "nanoid": "^4.0.2",
    "nats": "^2.29.3",
    "nestjs-cls": "catalog:",
    "nestjs-rate-limiter": "catalog:",
    "nestjs-supabase-auth": "catalog:",
    "nestjs-typeorm-paginate": "catalog:",
    "node-html-to-image": "^4.0.0",
    "node-qpdf2": "^2.0.0",
    "nodemailer": "^7.0.13",
    "p-limit": "^3.1.0",
    "papaparse": "^5.5.3",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "path": "^0.12.7",
