{
  "name": "@credebl/user-management",
  "version": "2.1.2",
  "main": "src/index",
  "types": "src/index",
  "license": "Apache-2.0",
  "publishConfig": {
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "access": "public"
  },
  "scripts": {
    "build": "pnpm run clean && pnpm run compile",
    "clean": "rimraf ./dist && rimraf tsconfig.lib.tsbuildinfo",
    "generate": "npx prisma generate --schema=node_modules/@credebl/prisma-service/prisma/schema.prisma",
    "cleanup": "rm -rf node_modules dist pnpm-lock.yaml && rm -rf ~/.cache/prisma ~/.pnpm-store",
    "compile": "tsc -p tsconfig.lib.json",
    "test": "jest"
  },
  "dependencies": {
    "@credebl/common": "workspace:*",
    "@credebl/prisma-service": "workspace:*",
    "@nestjs/axios": "catalog:",
    "@nestjs/common": "catalog:",
    "@nestjs/config": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/microservices": "catalog:",
    "@nestjs/swagger": "catalog:",
    "@supabase/supabase-js": "^2.53.0",
    "morgan": "^1.10.1",
    "rxjs": "^7.8.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "reflect-metadata": "^0.1.14",
    "rimraf": "^4.4.1",
    "typescript": "^5.8.3"
  }
}