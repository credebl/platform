{
  "name": "@credebl/config",
  "version": "2.1.2",
  "main": "src/index",
  "types": "src/index",
  "license": "Apache-2.0",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "publishConfig": {
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "access": "public"
  },
  "scripts": {
    "build": "pnpm run clean && pnpm run compile",
    "clean": "rimraf ./dist && rimraf tsconfig.lib.tsbuildinfo",
    "compile": "tsc -p tsconfig.lib.json"
  },
  "dependencies": {
    "@credebl/prisma-service": "workspace:*",
    "@nestjs/common": "catalog:",
    "@nestjs/config": "catalog:"
  },
  "devDependencies": {
    "rimraf": "^4.4.0",
    "typescript": "^5.1.6"
  }
}
