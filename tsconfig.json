{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "paths": {
      "@credebl/aws": [
        "libs/aws/src"
      ],
      "@credebl/aws/*": [
        "libs/aws/src/*"
      ],
      "@credebl/client-registration": [
        "libs/keycloak/src"
      ],
      "@credebl/client-registration/*": [
        "libs/keycloak/src/*"
      ],
      "@credebl/common": [
        "libs/common/src"
      ],
      "@credebl/common/*": [
        "libs/common/src/*"
      ],
      "@credebl/config": [
        "libs/config/src"
      ],
      "@credebl/config/*": [
        "libs/config/src/*"
      ],
      "@credebl/context": [
        "libs/common/src/utils/context"
      ],
      "@credebl/context/*": [
        "libs/common/src/utils/context/*"
      ],
      "@credebl/enum": [
        "libs/common/src/enum"
      ],
      "@credebl/enum/*": [
        "libs/common/src/enum/*"
      ],
      "@credebl/keycloak": [
        "libs/keycloak/src"
      ],
      "@credebl/keycloak/*": [
        "libs/keycloak/src/*"
      ],
      "@credebl/keycloak-config": [
        "libs/keycloak/src"
      ],
      "@credebl/keycloak-config/*": [
        "libs/keycloak/src/*"
      ],
      "@credebl/keycloak-url": [
        "libs/keycloak/src"
      ],
      "@credebl/keycloak-url/*": [
        "libs/keycloak/src/*"
      ],
      "@credebl/logger": [
        "libs/logger/src"
      ],
      "@credebl/logger/*": [
        "libs/logger/src/*"
      ],
      "@credebl/org-roles": [
        "libs/user-management/src"
      ],
      "@credebl/org-roles/*": [
        "libs/user-management/src/*"
      ],
      "@credebl/prisma": [
        "libs/prisma/src"
      ],
      "@credebl/prisma-service": [
        "libs/prisma-service/src"
      ],
      "@credebl/prisma-service/*": [
        "libs/prisma-service/src/*"
      ],
      "@credebl/prisma/*": [
        "libs/prisma/src/*"
      ],
      "@credebl/repositories": [
        "libs/repositories/src"
      ],
      "@credebl/repositories/*": [
        "libs/repositories/src/*"
      ],
      "@credebl/supabase": [
        "libs/supabase/src"
      ],
      "@credebl/supabase/*": [
        "libs/supabase/src/*"
      ],
      "credebl/utility": [
        "libs/utility/src"
      ],
      "credebl/utility/*": [
        "libs/utility/src/*"
      ],
      "@credebl/user-management": [
        "libs/user-management/src"
      ],
      "@credebl/user-management/*": [
        "libs/user-management/src/*"
      ]
    },
    "baseUrl": "./"
  },
  "exclude": [
    "node_modules",
    "dist"
  ]
}
