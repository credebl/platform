{
  "extends": "../../tsconfig.build.json",
  "compilerOptions": {
    "declaration": true,
    
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "incremental": false,
    "paths": {
      "@credebl/common": ["libs/common/dist"],
      "@credebl/common/*": ["libs/common/dist/*"],
      "@credebl/aws": ["libs/aws/dist"],
      "@credebl/aws/*": ["libs/aws/dist/*"],
      "@credebl/logger": ["libs/logger/dist"],
      "@credebl/logger/*": ["libs/logger/dist/*"],
      "@credebl/prisma-service": ["libs/prisma-service/dist"],
      "@credebl/prisma-service/*": ["libs/prisma-service/dist/*"],
      "@credebl/user-management": ["libs/user-management/dist"],
      "@credebl/user-management/*": ["libs/user-management/dist/*"],
      "@credebl/context": ["libs/common/dist"],
      "@credebl/context/*": ["libs/common/dist/*"],
      "@credebl/enum": ["libs/common/dist"],
      "@credebl/enum/*": ["libs/common/dist/*"],
      "@credebl/org-roles": ["libs/user-management/dist"],
      "@credebl/org-roles/*": ["libs/user-management/dist/*"],
      "@credebl/config": ["libs/config/dist"],
      "@credebl/config/*": ["libs/config/dist/*"],
      "@credebl/keycloak": ["libs/keycloak/dist"],
      "@credebl/keycloak/*": ["libs/keycloak/dist/*"],
      "@credebl/keycloak-config": ["libs/keycloak/dist"],
      "@credebl/keycloak-config/*": ["libs/keycloak/dist/*"],
      "@credebl/keycloak-url": ["libs/keycloak/dist"],
      "@credebl/keycloak-url/*": ["libs/keycloak/dist/*"],
      "@credebl/client-registration": ["libs/keycloak/dist"],
      "@credebl/client-registration/*": ["libs/keycloak/dist/*"],
      "@credebl/supabase": ["libs/supabase/src"],
      "@credebl/supabase/*": ["libs/supabase/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*spec.ts"]
}
