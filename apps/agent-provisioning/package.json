{
  "name": "@credebl/agent-provisioning",
  "version": "2.1.2",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "Apache-2.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf ./dist",
    "compile": "tsc -p tsconfig.pkg.json || true",
    "build": "pnpm run clean && pnpm run compile"
  },
  "dependencies": {
    "@credebl/common": "workspace:*",
    "@credebl/config": "workspace:*",
    "@credebl/logger": "workspace:*",
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/microservices": "catalog:",
    "dotenv": "^16.6.1",
    "nats": "^2.29.3",
    "rxjs": "^7.8.2"
  }
}
