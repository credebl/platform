{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "paths": {
      "@credebl/logger": [
        "libs/logger/src"
      ],
      "@credebl/logger/*": [
        "libs/logger/src/*"
      ],
      "@credebl/common": [
        "libs/common/dist"
      ],
      "@credebl/common/*": [
        "libs/common/dist/*"
      ],
      "@credebl/context": [
        "libs/context/dist"
      ],
      "@credebl/context/*": [
        "libs/context/dist/*"
      ]
    },
    "incremental": false
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "**/*spec.ts"
  ]
}