{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "incremental": false,
    "paths": {
      "@credebl/common": ["libs/common/src"],
      "@credebl/common/*": ["libs/common/src/*"],
      "@credebl/context": ["libs/context/dist"],
      "@credebl/context/*": ["libs/context/dist/*"]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "**/*spec.ts"
  ]
}