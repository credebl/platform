{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "paths": {
      "@credebl/common": [
        "../common/dist"
      ],
      "@credebl/common/*": [
        "../common/dist/*"
      ]
    },
    "incremental": false
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "**/*spec.ts",
    "prisma/**/*",
    "cli.ts"
  ]
}